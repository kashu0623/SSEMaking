  ],
  "respiratory_event_columns": [
    "Obstructive_Apnea",
    "Central_Apnea",
    "Hypopnea",
    "Multiple_Events"
  ],
  "default_model_input_policy": {
    "include": [
      "BVP",
      "ACC_X",
      "ACC_Y",
      "ACC_Z",
      "TEMP",
      "HR",
      "IBI"
    ],
    "optional_include_after_calibration_check": [
      "SAO2"
    ],
    "exclude_from_app_serving_model": [
      "C4-M1",
      "F4-M1",
      "O2-M1",
      "Fp1-O2",
      "T3 - CZ",
      "CZ - T4",
      "CHIN",
      "E1",
      "E2",
      "ECG",
      "LAT",
      "RAT",
      "SNORE",
      "PTAF",
      "FLOW",
      "THORAX",
      "ABDOMEN",
      "EDA",
