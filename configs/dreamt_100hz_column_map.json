  },
  "app_proxy_or_derived_columns_available_in_dreamt": {
    "BVP": "BVP",
    "HR": "HR",
    "IBI": "IBI",
    "SPO2": "SAO2"
  },
  "target_app_raw_columns_missing_in_dreamt": {
    "IR_PPG": null,
    "RED_PPG": null
  },
  "dreamt_only_psg_columns": [
